# 京东云 AX1800Pro 专属配置（1G内存 + 128G eMMC）
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_jdcloud_ax1800-pro=y

# 内核完整
CONFIG_KERNEL_BUILD_USER=""
CONFIG_KERNEL_BUILD_DOMAIN=""
CONFIG_KERNEL_CCACHE=y
CONFIG_KERNEL_DEBUG_INFO=y
CONFIG_KERNEL_DEBUG_INFO_REDUCED=n
CONFIG_KERNEL_KALLSYMS=y

# 软件源丰富（启用所有 feeds）
CONFIG_FEED_luci=y
CONFIG_FEED_packages=y
CONFIG_FEED_routing=y
CONFIG_FEED_telephony=y
CONFIG_FEED_freifunk=y

# 你要求的所有插件（全部勾选）
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-app-cifs-mount=y
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-filebrowser=y
CONFIG_PACKAGE_luci-app-partexp=y
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-app-timedreboot=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_luci-app-homeassistant=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-p910nd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-taskplan=y
CONFIG_PACKAGE_luci-app-dufs=y
CONFIG_PACKAGE_homeproxy=y

# 仿 iStoreOS 配置
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-advanced=y
CONFIG_PACKAGE_luci-app-fileassistant=y
CONFIG_PACKAGE_luci-app-ramfree=y
CONFIG_PACKAGE_luci-app-turboacc=y

# overlay 预留 10G（编译阶段固定）
CONFIG_TARGET_ROOTFS_PARTSIZE=10240

# Docker 数据分区 20G（编译阶段固定）
CONFIG_DOCKER_DATA_PART_SIZE=20480

# 128G eMMC 完整分区（刷入后清空原固件）
CONFIG_TARGET_ROOTFS_EXT4=y
CONFIG_TARGET_EXT4_MAX_INODES=65536
CONFIG_TARGET_EXT4_BLOCKSIZE=4096
CONFIG_TARGET_EXT4_JOURNAL=y
CONFIG_TARGET_EXT4_RESERVED_PCT=0
